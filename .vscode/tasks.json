{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile and Run Java",
            "type": "shell",
            "command": "sh",
            "args": [
                "-c",
                "cd ${workspaceFolder}/Parking_Lot/src && javac ${fileBasename} && java ${fileBasenameNoExtension}"
            ],
            "presentation": {
                "reveal": "always"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "java",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^(.*\\.java):(\\d+): (.*)$",
                    "file": 1,
                    "line": 2,
                    "message": 3
                }
            }
        }
    ]
}
